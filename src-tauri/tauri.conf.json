{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CorePTY",
  "version": "0.3.4",
  "identifier": "com.corepty.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CorePTY",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "center": true,
        "theme": "Dark",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'; form-action 'none'",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "conpty/conpty.dll": "conpty.dll",
      "conpty/OpenConsole.exe": "OpenConsole.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
